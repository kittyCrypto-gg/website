{
  "mainMenu": {
    "Main": {
      "href": "./",
      "icon": "/images/home.svg"
    },
    "About": {
      "href": "./about",
      "icon": "/images/info.svg"
    },
    "Stories": {
      "href": "./reader",
      "icon": "/images/bookshelf.svg"
    },
    "Guestbook": {
      "href": "./guestbook",
      "icon": "/images/book.svg"
    },
    "Chat": {
      "href": "./chat",
      "icon": "/images/chat.svg"
    },
    "Blog": {
      "href": "./blog",
      "icon": "/images/yarn.svg"
    }
  },
  "header": "${pageTitle}",
  "footer": "Kitty's website is open-source. 2024 - ${year}",
  "themeToggle": {
    "light": "🌙",
    "lightIconPath": "/images/moon.svg",
    "dark": "☀️",
    "darkIconPath": "/images/sun.svg",
    "title": "Theme"
  },
  "readerModeToggle": {
    "enable": "📖",
    "enableIconPath": "/images/book-open.svg",
    "disable": "📕",
    "disableIconPath": "/images/book-closed.svg",
    "title": "Reader Mode"
  },
  "readAloudToggle": {
    "enable": "🔊",
    "disable": "🔇",
    "iconPath": "/images/speaker.svg",
    "title": "Read Aloud"
  },
  "effects": {
    "icon": "📺",
    "iconPath": "/images/imacG3.svg",
    "title": "CRT Effects",
    "modal": {
      "title": "CRT Effects",
      "lead": "Tune the phosphor mask and scan lines to taste. Changes apply instantly and stay saved in this browser.",
      "closeTitle": "Close effects",
      "phosphorTitle": "Phosphor mask",
      "phosphorDescription": "Controls the Trinitron-style RGB lattice.",
      "phosphorToggle": "Disable phosphor mask",
      "intensityLabel": "Intensity",
      "phosphorHint": "Trinitron aperture-grill vibes. From old CRT hum to ‘that telly is absolutely not surviving the winter’.",
      "scanlinesTitle": "Scan lines",
      "scanlinesDescription": "Controls the moving horizontal pass.",
      "scanlinesToggle": "Disable scan lines",
      "scanlinesHint": "This is the bright cyan sweep, from subtle ghost to arcade fever.",
      "scanlineSpeedLabel": "Speed",
      "scanlineSpeedHint": "Controls how fast the cyan sweep travels. From still tpo ‘the tube is speaking in tongues’.",
      "reset": "Reset to defaults",
      "done": "Done"
    }
  },
  "crtUi": {
    "icon": "🎛️",
    "iconPath": "/images/controls.svg",
    "title": "CRT Noise Control Desk",
    "modal": {
      "title": "CRT Noise Control Desk",
      "lead": "Swap between PAL and NTSC presets, or set a custom frequency.",
      "closeTitle": "Close CRT noise control desk",
      "transportTitle": "Transport",
      "presetAndFrequencyTitle": "Preset and frequency",
      "layerTogglesTitle": "Layer toggles",
      "levelsTitle": "Levels",
      "statusTitle": "Status",
      "presetFamilyLabel": "Preset family",
      "presetPalLabel": "PAL preset",
      "presetNtscLabel": "NTSC preset",
      "baseFrequencyLabel": "Base frequency",
      "masterLabel": "Master",
      "scanlineLabel": "Scanline",
      "humLabel": "Hum",
      "rectifierLabel": "Rectifier",
      "degaussLabel": "Degauss",
      "collapseLabel": "Flyback voltage collapse",
      "dischargeLabel": "Relay drop-out",
      "runningLabel": "Running",
      "standardLabel": "Standard",
      "baseLabel": "Base",
      "lineFrequencyLabel": "Line frequency",
      "retriggerDegauss": "Degauss",
      "restore": "Restore defaults",
      "none": "None",
      "startPrefix": "Start",
      "stopPrefix": "Stop",
      "plotSpectrogram": "Plot: Spectrogram",
      "plotWaveform": "Plot: Waveform",
      "idleStatus": "Idle",
      "runningStatus": "Running"
    }
  },
  "headScripts": [],
  "headerInjections": [
    "<meta name=\"viewport\" content=\"width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no\">",
    "<meta charset=\"UTF-8\">",
    "<meta property=\"og:type\" content=\"website\">",
    "<script src=\"https://cdn.jsdelivr.net/npm/marked/marked.min.js\"></script>"
  ],
  "windows": {
    "kittyIntro": {
      "selector": "#kitty-intro-wrapper",
      "options": {
        "id": "kitty-intro",
        "title": "Introduction",
        "mountTarget": "body",
        "launcherSrc": "/images/about.svg"
      }
    },
    "noticeBoard": {
      "selector": "#notice-board-wrapper",
      "options": {
        "id": "notice-board",
        "title": "Notice Board",
        "mountTarget": "body",
        "launcherSrc": "/images/calendar.svg"
      }
    },
    "commitsWrapper": {
      "selector": "#commits-outer-shell",
      "options": {
        "id": "commits-wrapper",
        "title": "Source Code Tracker",
        "mountTarget": "body",
        "launcherSrc": "/images/factory.svg"
      }
    },
    "frontendCommitsWrapper": {
      "selector": "#frontend-commits-window",
      "options": {
        "id": "frontend-commits",
        "title": "Front-end Commits",
        "launcherSrc": "/images/template.svg"
      }
    },
    "backendCommitsWrapper": {
      "selector": "#backend-commits-window",
      "options": {
        "id": "backend-commits",
        "title": "Back-end Commits",
        "launcherSrc": "/images/electronics.svg"
      }
    },
    "sitesILikeWrapper": {
      "selector": "#sites-i-like",
      "options": {
        "id": "sites-i-like",
        "title": "Sites I find Interesting",
        "mountTarget": "body",
        "launcherSrc": "/images/mind_map.svg"
      }
    },
    "myButtonWrapper": {
      "selector": "#my-button",
      "options": {
        "id": "my-button",
        "title": "My Button",
        "mountTarget": "body",
        "launcherSrc": "/images/share.svg"
      }
    },
    "commentsWrapper": {
      "selector": "#comments",
      "options": {
        "id": "comments-wrapper",
        "title": "Comments",
        "mountTarget": "body",
        "launcherSrc": "/images/comments.svg"
      }
    },
    "homeSiteStats": {
      "selector": "#site-stats",
      "options": {
        "id": "site-stats",
        "title": "Stats",
        "mountTarget": "body",
        "launcherSrc": "/images/display.svg"
      }
    },
    "presenceWindow": {
      "selector": "#presence-window-wrapper",
      "forceFreshStateOnLoad": true,
      "options": {
        "id": "presence-window",
        "title": "Status",
        "mountTarget": "body",
        "launcherSrc": "/images/miku.svg"
      }
    },
    "aboutMe": {
      "selector": "#kitty-about",
      "options": {
        "id": "about-me",
        "title": "About Me",
        "mountTarget": "body"
      }
    },
    "socials": {
      "selector": ".socials-segment",
      "options": {
        "id": "socials",
        "title": "Find me elsewhere",
        "mountTarget": "body"
      }
    },
    "aboutSiteStats": {
      "selector": ".site-stats",
      "options": {
        "id": "site-stats",
        "title": "Stats",
        "mountTarget": "body"
      }
    },
    "terminalWindow": {
      "selector": "#shell-wrapper",
      "options": {
        "id": "terminal",
        "title": "Terminal Emulator",
        "mountTarget": "body",
        "launcherSrc": "/images/terminal.svg",
        "closedLnchrDis": "inline-block",
        "showCloseBttn": true
      }
    },
    "blogWrapper": {
      "selector": ".blog-wrapper",
      "options": {
        "id": "blog-window",
        "title": "Blog Posts",
        "mountTarget": "body",
        "launcherSrc": "/images/yarn.svg"
      }
    },
    "storyWindow": {
      "selector": "#story-window-wrapper",
      "options": {
        "id": "story-window",
        "title": "Reader",
        "mountTarget": "body"
      }
    },
    "chatWindow": {
      "selector": "#chat-window",
      "options": {
        "id": "chat-window",
        "title": "Kitty Chat",
        "mountTarget": "body"
      }
    }
  }
}